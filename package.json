{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "dev:e2e": "vite --mode e2e --host 127.0.0.1 --port 5173 --strictPort",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:jest": "jest",
    "test:jest:watch": "jest --watch",
    "test:jest:coverage": "jest --coverage",
    "test:selenium": "npm run test:selenium:all",
    "test:selenium:all": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/*.selenium.test.mjs\"",
    "test:selenium:about": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/about.selenium.test.mjs\"",
    "test:selenium:auth": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/auth.selenium.test.mjs\"",
    "test:selenium:compound-interest": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/compound-interest.selenium.test.mjs\"",
    "test:selenium:converter": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/interest-rate-converter.selenium.test.mjs\"",
    "test:selenium:dashboard": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/dashboard.selenium.test.mjs\"",
    "test:selenium:dashboard:compose": "cd ../invest_calc_backend && docker compose --profile e2e up -d --build app-e2e && cd ../invest_calc_frontend && npm run test:selenium:dashboard",
    "test:selenium:financial-profile": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/financial-profile.selenium.test.mjs\"",
    "test:selenium:financial-profile:compose": "cd ../invest_calc_backend && docker compose --profile e2e up -d --build app-e2e && cd ../invest_calc_frontend && npm run test:selenium:financial-profile",
    "test:selenium:financial-summary": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/financial-summary.selenium.test.mjs\"",
    "test:selenium:goals": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/goals.selenium.test.mjs\"",
    "test:selenium:mysql": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"E2E_REQUIRE_MYSQL=true node --test --test-concurrency=1 ./e2e/investcalc.mysql.selenium.test.mjs\"",
    "test:selenium:password-recovery": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/password-recovery.selenium.test.mjs\"",
