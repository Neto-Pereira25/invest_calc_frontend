    "test:selenium:transactions": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/transactions.selenium.test.mjs\"",
    "test:selenium:transactions:mysql": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"E2E_REQUIRE_MYSQL=true node --test --test-concurrency=1 ./e2e/transactions.selenium.test.mjs\"",
    "test": "npm run test:e2e",
    "test:e2e": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/auth.selenium.test.mjs ./e2e/transactions.selenium.test.mjs ./e2e/compound-interest.selenium.test.mjs ./e2e/goals.selenium.test.mjs\"",
    "test:e2e:financial-summary": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/financial-summary.selenium.test.mjs\"",
    "test:e2e:goals": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/goals.selenium.test.mjs\"",
    "test:e2e:password-recovery": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/password-recovery.selenium.test.mjs\"",
    "test:e2e:spending-limit": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/spending-limit.selenium.test.mjs\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "axios": "^1.15.2",
    "bootstrap": "^5.3.8",
