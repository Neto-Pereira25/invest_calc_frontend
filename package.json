    "test:selenium:reverse-simulation:compose": "cd ../invest_calc_backend && docker compose --profile e2e up -d --build app-e2e && cd ../invest_calc_frontend && npm run test:selenium:reverse-simulation",
    "test:selenium:scenario-comparison": "start-server-and-test dev:e2e http://127.0.0.1:5173 \"node --test --test-concurrency=1 ./e2e/scenario-comparison.selenium.test.mjs\"",
    "test:selenium:scenario-comparison:compose": "cd ../invest_calc_backend && docker compose --profile e2e up -d --build app-e2e && cd ../invest_calc_frontend && npm run test:selenium:scenario-comparison",
